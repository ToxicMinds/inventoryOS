# Environment Variables — Copy to .env and fill in values

# --- Database (local PostgreSQL) ---
DB_HOST=localhost
DB_PORT=5432
DB_NAME=inventoryos
DB_USER=inventoryos
DB_PASSWORD=inventoryos_dev

# --- Auth ---
JWT_SECRET=change-me-in-production-must-be-at-least-32-chars
JWT_EXPIRY_HOURS=8

# --- Backend ---
BACKEND_PORT=8080
SPRING_PROFILES_ACTIVE=local

# --- Frontend ---
NEXT_PUBLIC_API_URL=http://localhost:8080/api
NEXT_PUBLIC_APP_NAME=InventoryOS
NEXTAUTH_SECRET=change-me-in-production
NEXTAUTH_URL=http://localhost:3001

# --- Google Gemini (Optional - for OCR invoice scanning) ---
GEMINI_API_KEY=your-gemini-api-key-here

# --- AWS (Production only - leave blank for local dev) ---
AWS_REGION=us-east-1
AWS_DYNAMODB_TABLE=inventoryos-events
AWS_COGNITO_USER_POOL_ID=
AWS_COGNITO_CLIENT_ID=
AWS_S3_BUCKET=
